+def __exec_multi_process(fun: Callable[[T], U], vals: List[T], num_procs: int = NUM_PROCS, desc: str = "") -> List[U]:
+    results = []
+    with Pool(num_procs, initializer=process_initializer) as p, tqdm(total=len(vals), desc=desc) as pbar:
